<configuration>
    <configSections>
    </configSections>
    <connectionStrings>
        <add name="Data_Lab_2.Properties.Settings.masterConnectionString"
            connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=master;Integrated Security=True"
            providerName="System.Data.SqlClient" />
